# Puerto del servidor
PORT=8001

# Entorno
NODE_ENV=development

# IBM Bob Shell (opcional)
# Si configuras esta variable, el endpoint /api/scope/analyze intentará usar Bob.
# Si no está configurada, usará el analizador local determinístico.
BOBSHELL_API_KEY=
# bobshell 1.0.3 también espera GEMINI_API_KEY con el mismo valor.
# El backend lo inyecta automáticamente si no existe, así que esta línea es opcional.
GEMINI_API_KEY=
BOB_TIMEOUT_SECONDS=150
